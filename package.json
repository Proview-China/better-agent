{
  "name": "praxis",
  "version": "0.1.0",
  "private": true,
  "description": "Blank-slate reboot scaffold for Praxis.",
  "type": "module",
  "packageManager": "npm@11.6.4",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "check": "npm run typecheck && npm run build",
    "test": "npm run build && node --test dist/**/*.test.js",
    "test:refactor:list": "node scripts/refactor-test-gates.mjs list",
    "test:refactor:show": "node scripts/refactor-test-gates.mjs show",
    "test:refactor:gate": "node scripts/refactor-test-gates.mjs run",
    "cmp:infra:up": "docker compose -f infra/cmp/compose.yaml --env-file infra/cmp/.env up -d",
    "cmp:infra:down": "docker compose -f infra/cmp/compose.yaml --env-file infra/cmp/.env down",
    "cmp:infra:ps": "docker compose -f infra/cmp/compose.yaml --env-file infra/cmp/.env ps",
    "cmp:infra:status": "node -e \"fetch('http://127.0.0.1:' + (process.env.CMP_STATUS_PORT || '57480') + '/status').then(r=>r.text()).then(t=>process.stdout.write(t + '\\n'))\"",
    "smoke:cmp:five-agent:live": "tsx src/rax/cmp-five-agent-live-smoke.ts",
    "smoke:thin:live": "tsx src/rax/live-smoke.ts",
    "smoke:websearch:live": "tsx src/rax/websearch-live-smoke.ts",
    "smoke:skill:live": "tsx src/rax/skill-live-smoke.ts",
    "smoke:skill:execution:live": "tsx src/rax/skill-execution-live-smoke.ts",
    "report:skill:capability": "tsx src/rax/skill-capability-report.ts",
    "smoke:mcp:playwright": "tsx src/rax/mcp-playwright-smoke.ts",
    "smoke:mcp:models": "tsx src/rax/mcp-model-live-smoke.ts",
    "smoke:mcp:native:live": "tsx src/rax/mcp-native-live-smoke.ts",
    "smoke:single-agent:live": "tsx src/agent_core/single-agent-live-smoke.ts",
    "cmp:status:serve": "node scripts/cmp-status-panel-server.mjs",
    "start": "node dist/index.js"
  },
  "devDependencies": {
    "@types/node": "^24.6.0",
    "tsx": "^4.20.5",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.74",
    "@anthropic-ai/sdk": "^0.78.0",
    "@google/adk": "^0.5.0",
    "@google/genai": "^1.45.0",
    "@lancedb/lancedb": "^0.27.2",
    "@openai/agents": "^0.7.0",
    "apache-arrow": "^18.1.0",
    "openai": "^6.27.0",
    "zod": "^4.3.6"
  }
}
