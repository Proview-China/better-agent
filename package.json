{
  "name": "praxis",
  "version": "0.1.0",
  "private": true,
  "description": "Blank-slate reboot scaffold for Praxis.",
  "type": "module",
  "packageManager": "npm@11.6.4",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "check": "npm run typecheck && npm run build",
    "test": "npm run build && node --test dist/**/*.test.js",
    "smoke:thin:live": "tsx src/rax/live-smoke.ts",
    "start": "node dist/index.js"
  },
  "devDependencies": {
    "@types/node": "^24.6.0",
    "tsx": "^4.20.5",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.74",
    "@anthropic-ai/sdk": "^0.78.0",
    "@google/adk": "^0.5.0",
    "@google/genai": "^1.45.0",
    "@openai/agents": "^0.7.0",
    "openai": "^6.27.0",
    "zod": "^4.3.6"
  }
}
